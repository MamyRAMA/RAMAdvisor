# Variables d'environnement pour le service RAM Advisor AI

# OpenAI API Key (optionnel - pour une meilleure qualité de réponse)
# OPENAI_API_KEY=your_openai_api_key_here

# Configuration du service
SERVICE_PORT=8000
SERVICE_HOST=0.0.0.0

# Répertoires
KNOWLEDGE_DIR=../docs/knowledge
INDEX_DIR=./indexes

# Modèle d'embeddings (par défaut: sentence-transformers/all-MiniLM-L6-v2)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paramètres de chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Paramètres de recherche
DEFAULT_TOP_K=5
MAX_TOP_K=10
